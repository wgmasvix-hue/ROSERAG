# ════════════════════════════════════════════════════════════════
# ROSERAG — Environment Configuration
# Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────
# "ollama"  → local Ollama (default, zero cost, no API key needed)
# "openai"  → any OpenAI-compatible API (Groq, OpenAI, Together…)
LLM_PROVIDER=ollama

# ── Option A: Local Ollama (default) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2

# ── Option B: Groq + Jina AI (free cloud) ────────────────────────
# 1. Get a free Groq key at: https://console.groq.com
# 2. Get a free Jina key at: https://jina.ai  (1M tokens/month free)
# Then set:
#
# LLM_PROVIDER=openai
# LLM_API_KEY=gsk_xxxxxxxxxxxx          ← your Groq API key
# LLM_API_BASE=https://api.groq.com/openai
# CHAT_MODEL=llama-3.3-70b-versatile
#
# EMBED_API_KEY=jina_xxxxxxxxxxxx        ← your Jina API key
# EMBED_API_BASE=https://api.jina.ai
# EMBED_MODEL=jina-embeddings-v2-base-en

LLM_API_KEY=
LLM_API_BASE=
EMBED_API_KEY=
EMBED_API_BASE=

# ── Qdrant ────────────────────────────────────────────────────────
# Local:  leave QDRANT_API_KEY blank, QDRANT_USE_HTTPS=false
# Cloud:  set QDRANT_HOST, QDRANT_API_KEY, QDRANT_USE_HTTPS=true
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_USE_HTTPS=false
COLLECTION_NAME=roserag

# ── RAG Parameters ────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
DATA_DIR=data
