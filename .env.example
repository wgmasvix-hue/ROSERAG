# ── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama"  → local Ollama server (default, no API key needed)
# "openai"  → any OpenAI-compatible API (Groq, OpenAI, Together, etc.)
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2

# Cloud provider (used when LLM_PROVIDER=openai)
# Groq example:  LLM_API_BASE=https://api.groq.com/openai  CHAT_MODEL=llama-3.3-70b-versatile
# OpenAI example: leave LLM_API_BASE blank, CHAT_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_API_BASE=

# Optional: separate embeddings provider (blank = use LLM_API_BASE / LLM_API_KEY)
# Nomic example: EMBED_API_BASE=https://api-atlas.nomic.ai  EMBED_MODEL=nomic-embed-text-v1.5
EMBED_API_BASE=
EMBED_API_KEY=

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_USE_HTTPS=false
COLLECTION_NAME=roserag

# ── RAG ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
DATA_DIR=data
