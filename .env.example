# ════════════════════════════════════════════════════════════════
# ROSERAG — Environment Configuration
# Run `roserag init` to generate this file interactively.
# ════════════════════════════════════════════════════════════════

# ── Institution Branding ─────────────────────────────────────────
# Customise these to white-label the platform for your institution.
INSTITUTION_NAME=Institutional Intelligence Platform
INSTITUTION_TAGLINE=Retrieve · Reason · Respond
BRAND_PREFIX=ROSE           # Left half of the logo (e.g. MIT, HARV, UCL)
BRAND_SUFFIX=RAG            # Right half of the logo (e.g. IQ, RAG, KOS)
BRAND_COLOR_PRIMARY=#9b2248 # Main accent colour (hex)
BRAND_COLOR_ACCENT=#d44e72  # Lighter accent / active state (hex)

# ── LLM Provider ─────────────────────────────────────────────────
# "ollama"  → local Ollama (default, for local dev, no API key needed)
# "openai"  → cloud API (DeepSeek, Groq, OpenAI, etc.)
LLM_PROVIDER=ollama

# ══ LOCAL DEV (LLM_PROVIDER=ollama) ══════════════════════════════
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ══ VERCEL / CLOUD (LLM_PROVIDER=openai) ═════════════════════════
# The endpoints below are PRE-CONFIGURED for DeepSeek + Jina AI.
# You only need to provide the two API keys:

# Chat → DeepSeek  (platform.deepseek.com)
LLM_API_KEY=            # ← your DeepSeek key  (sk-...)
LLM_API_BASE=https://api.deepseek.com
CHAT_MODEL=deepseek-chat

# Embeddings → Jina AI  (jina.ai — 1M tokens/month free)
EMBED_API_KEY=          # ← your Jina AI key  (jina_...)
EMBED_API_BASE=https://api.jina.ai
EMBED_MODEL=jina-embeddings-v2-base-en

# ── Qdrant ────────────────────────────────────────────────────────
# Local:  leave QDRANT_API_KEY blank
# Cloud:  get a free cluster at cloud.qdrant.io
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_USE_HTTPS=false
COLLECTION_NAME=roserag

# ── RAG ──────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
DATA_DIR=data
