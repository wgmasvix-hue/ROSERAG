# ════════════════════════════════════════════════════════════════
# ROSERAG — Environment Configuration
# Copy to .env and fill in your API keys.
# ════════════════════════════════════════════════════════════════

# ── Institution Branding ─────────────────────────────────────────
INSTITUTION_NAME=Institutional Intelligence Platform
INSTITUTION_TAGLINE=Retrieve · Reason · Respond
BRAND_PREFIX=ROSE
BRAND_SUFFIX=RAG
BRAND_COLOR_PRIMARY=#9b2248
BRAND_COLOR_ACCENT=#d44e72

# ── DeepSeek (Chat + Reasoning) ──────────────────────────────────
# Get your key at: platform.deepseek.com → API Keys
LLM_API_KEY=sk-...              # ← required
LLM_API_BASE=https://api.deepseek.com
CHAT_MODEL=deepseek-chat
REASONER_MODEL=deepseek-reasoner

# ── Jina AI (Embeddings) ─────────────────────────────────────────
# Get your key at: jina.ai → API Keys  (1 M tokens/month free)
EMBED_API_KEY=jina_...          # ← required
EMBED_API_BASE=https://api.jina.ai
EMBED_MODEL=jina-embeddings-v5-omni-nano

# ── Qdrant ────────────────────────────────────────────────────────
# Local:  leave QDRANT_API_KEY blank
# Cloud:  get a free cluster at cloud.qdrant.io
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_USE_HTTPS=false
COLLECTION_NAME=roserag

# ── RAG ──────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
DATA_DIR=data
